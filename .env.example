# ============================================================
# PiPiBook — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NODE_ENV=development
PORT=4000

# ------------------------------------------------------------
# Database
# PostgreSQL connection string.
# Development: points to the docker-compose postgres service.
# Production: use your Supabase "Transaction" pooler URL.
# ------------------------------------------------------------
DATABASE_URL=postgresql://pipibook:pipibook@localhost:5432/pipibook

# ------------------------------------------------------------
# Redis
# Development: points to the docker-compose redis service.
# Production: use your Upstash Redis REST URL (rediss://...).
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# JWT
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------
# LINE Login / Messaging API
# Create a channel at https://developers.line.biz/console/
# ------------------------------------------------------------
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_REDIRECT_URI=http://localhost:3000/auth/callback
LINE_LIFF_ID=

# ------------------------------------------------------------
# ECPay (Taiwan payment gateway)
# Test credentials: https://vendor.ecpay.com.tw/
# ECPAY_MERCHANT_ID for staging = 2000132
# ------------------------------------------------------------
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_RETURN_URL=https://yourdomain.com/api/payments/ecpay/return
ECPAY_ORDER_RESULT_URL=https://yourdomain.com/api/payments/ecpay/result

# ------------------------------------------------------------
# URLs
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# ------------------------------------------------------------
# Next.js Public Variables
# These are embedded into the browser bundle — do NOT put
# secrets here. Prefix must be NEXT_PUBLIC_.
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_LINE_CHANNEL_ID=
NEXT_PUBLIC_LINE_LIFF_ID=
