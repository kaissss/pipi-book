# ============================================================
# PiPiBook Backend — Environment Variables
# Copy to .env (local) and set the same values in Railway Variables.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
# Comma-separated allowed frontend origins (production). Leave empty in dev to allow all.
CORS_ORIGINS=
# Public frontend base URL — used to redirect the buyer back after ECPay.
# Falls back to the first CORS_ORIGINS entry when unset.
FRONTEND_URL=http://localhost:3000
# Set ENABLE_SWAGGER=false to hide /api/docs in production.
ENABLE_SWAGGER=true
# Dev-only LINE-less login (POST /auth/dev/login). Local/staging only — NEVER set
# this to true on Railway/production.
DEV_LOGIN_ENABLED=false

# --- Database (Supabase) ---
# DATABASE_URL: transaction pooler (port 6543) — used by the app at runtime.
# DIRECT_URL:   direct connection (port 5432) — used by prisma migrate.
DATABASE_URL=postgresql://user:password@localhost:5432/pipibook
DIRECT_URL=postgresql://user:password@localhost:5432/pipibook

# --- Redis (Upstash) ---
REDIS_URL=rediss://default:password@your-endpoint.upstash.io:6379
# REDIS_TOKEN: only needed for the Upstash REST API (optional).
REDIS_TOKEN=

# --- JWT ---
JWT_SECRET=change-me-to-a-64-byte-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-64-byte-random-string
JWT_REFRESH_EXPIRES_IN=7d

# --- LINE Login ---
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_REDIRECT_URI=http://localhost:3000/auth/callback

# --- LINE Messaging API ---
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=your-line-messaging-access-token
LINE_MESSAGING_CHANNEL_SECRET=your-line-messaging-channel-secret

# --- ECPay (sandbox values shown; replace for production) ---
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
# Both ECPay callbacks are BACKEND endpoints (ECPay POSTs to them). They live at
# stable, UNVERSIONED paths (no /api/v1) — note the plural "payments".
# The buyer's browser returns to the frontend via ClientBackURL (= FRONTEND_URL).
#   ReturnURL      = server-to-server webhook (authoritative, responds 1|OK)
#   OrderResultURL = browser POST after payment; backend 303-redirects to the app
ECPAY_RETURN_URL=http://localhost:4000/payments/webhook
ECPAY_ORDER_RESULT_URL=http://localhost:4000/payments/result

# --- Slot locking ---
SLOT_LOCK_TTL_SECONDS=300
