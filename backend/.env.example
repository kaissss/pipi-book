# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pipibook

# Redis (Upstash)
REDIS_URL=redis://default:password@your-upstash-endpoint.upstash.io:6379
REDIS_TOKEN=your-upstash-token

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# LINE Login
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_REDIRECT_URI=http://localhost:3000/auth/line/callback

# LINE Messaging API
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=your-line-messaging-channel-access-token
LINE_MESSAGING_CHANNEL_SECRET=your-line-messaging-channel-secret

# ECPay
ECPAY_MERCHANT_ID=your-ecpay-merchant-id
ECPAY_HASH_KEY=your-ecpay-hash-key
ECPAY_HASH_IV=your-ecpay-hash-iv
ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_RETURN_URL=http://localhost:3000/payment/webhook
ECPAY_ORDER_RESULT_URL=http://localhost:3000/payment/result

# BullMQ
BULL_REDIS_URL=redis://default:password@your-upstash-endpoint.upstash.io:6379

# Slot Locking
SLOT_LOCK_TTL_SECONDS=300
