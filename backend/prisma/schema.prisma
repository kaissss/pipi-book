generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct connection (Supabase port 5432) used by `prisma migrate`.
  // DIRECT_URL must be set — Prisma does NOT fall back to DATABASE_URL. For a
  // local Postgres without a pooler, set DIRECT_URL to the same value as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  COACH
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CoachStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ServiceType {
  ONE_ON_ONE
  GROUP
  WORKSHOP
}

enum SlotStatus {
  OPEN
  LOCKED
  BOOKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  ATM
  CVS
  BARCODE
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  GENERAL
}

model User {
  id          String     @id @default(uuid())
  email       String?    @unique
  phone       String?    @unique
  lineUserId  String?    @unique @map("line_user_id")
  avatar      String?
  displayName String?    @map("display_name")
  role        Role       @default(STUDENT)
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  coach         Coach?
  bookings      Booking[]       @relation("MemberBookings")
  notifications Notification[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Coach {
  id             String      @id @default(uuid())
  userId         String      @unique @map("user_id")
  bio            String      @default("")
  specialties    String[]
  experience     Int         @default(0)
  status         CoachStatus @default(PENDING)
  timezone       String      @default("Asia/Taipei")
  location       String?
  languages      String[]
  certifications String[]
  coverImageUrl  String?     @map("cover_image_url")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  services  Service[]
  slots     AvailableSlot[]
  bookings  Booking[]         @relation("PiPiBookings")

  @@map("coaches")
}

model Service {
  id              String      @id @default(uuid())
  coachId         String      @map("coach_id")
  name            String
  description     String      @default("")
  type            ServiceType @default(ONE_ON_ONE)
  durationMinutes Int         @map("duration_minutes")
  price           Decimal     @db.Decimal(10, 2)
  currency        String      @default("TWD")
  maxParticipants Int         @default(1) @map("max_participants")
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  coach    Coach     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("services")
}

model AvailableSlot {
  id          String     @id @default(uuid())
  coachId     String     @map("coach_id")
  startTime   DateTime   @map("start_time")
  endTime     DateTime   @map("end_time")
  status      SlotStatus @default(OPEN)
  lockedUntil DateTime?  @map("locked_until")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  coach   Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  booking Booking?

  @@map("available_slots")
}

model Booking {
  id            String        @id @default(uuid())
  memberId      String        @map("member_id")
  coachId       String        @map("coach_id")
  serviceId     String        @map("service_id")
  slotId        String        @unique @map("slot_id")
  bookingStatus BookingStatus @default(PENDING) @map("booking_status")
  notes         String?
  meetingUrl    String?       @map("meeting_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  member  User          @relation("MemberBookings", fields: [memberId], references: [id])
  coach   Coach         @relation("PiPiBookings", fields: [coachId], references: [id])
  service Service       @relation(fields: [serviceId], references: [id])
  slot    AvailableSlot @relation(fields: [slotId], references: [id])
  payment Payment?

  @@map("bookings")
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique @map("booking_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  ecpayTradeNo  String?       @unique @map("ecpay_trade_no")
  ecpayData     Json?         @map("ecpay_data")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  content   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
