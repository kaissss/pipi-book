# API — must match the backend host/port (backend defaults to PORT=4000).
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Dev-only: show LINE-less role login buttons on /auth/login. Local only — leave
# unset/false on Vercel. Requires the backend to also have DEV_LOGIN_ENABLED=true.
NEXT_PUBLIC_DEV_LOGIN=false

# LINE LIFF
NEXT_PUBLIC_LIFF_ID=your-liff-id-here
NEXT_PUBLIC_LINE_CHANNEL_ID=your-line-channel-id
NEXT_PUBLIC_LINE_REDIRECT_URI=http://localhost:3000/auth/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PiPiBook

# ECPay (payment)
NEXT_PUBLIC_ECPAY_MERCHANT_ID=your-ecpay-merchant-id

# JWT
JWT_SECRET=your-jwt-secret-here
